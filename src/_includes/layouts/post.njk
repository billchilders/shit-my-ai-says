---
layout: layouts/base.njk
---
<article class="post-detail">
  <a class="back-link" href="/">← Back to gallery</a>
  <header class="post-header">
    <p class="eyebrow">Exhibit</p>
    <h1>{{ title }}</h1>
    <p class="post-date">{{ date | displayDate }}</p>
  </header>

  <figure class="post-figure">
    <img src="/{{ image }}" alt="Screenshot of a chat moment titled {{ title }}">
  </figure>

  {% if caption %}
  <section class="post-caption">
    <h2>Setup</h2>
    <p>{{ caption }}</p>
  </section>
  {% endif %}

  <section class="tuesday-comment">
    <h2>Tuesday’s comment</h2>
    <p>{{ tuesdayComment }}</p>
  </section>

  {% if tags and tags.length %}
  <ul class="tag-list">
    {% for tag in tags %}
    <li>{{ tag }}</li>
    {% endfor %}
  </ul>
  {% endif %}
</article>
