---
layout: layouts/base.njk
---
<article class="post-detail">
  <a class="back-link" href="{{ site.baseUrl }}">← Back to gallery</a>
  <header class="post-header">
    <div>
      <p class="eyebrow">Exhibit</p>
      <h1>{{ title }}</h1>
    </div>
    <p class="post-date">{{ date | displayDate }}</p>
  </header>

  <figure class="post-figure">
    <img src="{% asset image %}" alt="Screenshot of a chat moment titled {{ title }}">
  </figure>

  <section class="post-meta-grid">
    {% if caption %}
    <section class="post-caption">
      <p class="section-label">Setup</p>
      <p>{{ caption }}</p>
    </section>
    {% endif %}

    <section class="tuesday-comment">
      <p class="section-label">Tuesday’s comment</p>
      <p>{{ tuesdayComment }}</p>
    </section>
  </section>

  {% if tags and tags.length %}
  <ul class="tag-list">
    {% for tag in tags %}
    <li>{{ tag }}</li>
    {% endfor %}
  </ul>
  {% endif %}
</article>
